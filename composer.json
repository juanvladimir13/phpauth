{
    "name": "juanvladimir13/phpauth",
    "description": "PHP authentication & authorization system with RBAC, CSRF, rate limiting, and PostgreSQL",
    "type": "library",
    "license": "MIT",
    "homepage": "https://juanvladimir13.web.app/",
    "authors": [
        {
            "name": "Juan Vladimir",
            "email": "juanvladimir13@gmail.com",
            "homepage": "https://juanvladimir13.web.app/"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "ext-yaml": "*",
        "juanvladimir13/postgres-database": "^0.1.7"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "vimeo/psalm": "^5.18",
        "squizlabs/php_codesniffer": "^3.8",
        "friendsofphp/php-cs-fixer": "^3.45",
        "phpunit/phpunit": "^9.5"
    },
    "repositories": [],
    "autoload": {
        "psr-4": {
            "PhpAuth\\": "src/"
        },
        "files": []
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "prepend-autoloader": false,
        "platform": {
            "php": "8.4"
        }
    },
    "scripts": {
        "start": "php -S localhost:8013 -t ./public",
        "phpstan": "vendor/bin/phpstan analyse --autoload-file=vendor/autoload.php -c phpstan.neon",
        "psalm": "vendor/bin/psalm src",
        "phpcs": "vendor/bin/phpcs --colors --standard=PSR12 --severity=1 --tab-width=4 --report=summary src",
        "phpcs-detail": "vendor/bin/phpcs --colors --standard=PSR12 --severity=1 --tab-width=4 src",
        "phpcs-fixer": "vendor/bin/php-cs-fixer fix src --rules=@PSR12",
        "test": "vendor/bin/phpunit",
        "post-install-cmd": [
            "php -r \"copy('vendor/juanvladimir13/phpauth/auth', 'auth');\""
        ]
    }
}